# Service identity
ATTENDAI_AI_SERVICE_NAME=attendai-ai
ATTENDAI_AI_VERSION=0.1.0

# Shared key used by the Spring Boot backend (X-Service-Key header).
# Match this with `app.ai.service-key` in the Java backend's application.yml.
ATTENDAI_AI_SERVICE_KEY=dev-service-key

# Face backend: 'stub' (default, no deps) | 'opencv' (real detection, requires opencv-python-headless)
ATTENDAI_AI_FACE_BACKEND=stub

# Local directory used by the file-based embedding store. Swap for Redis/Postgres
# in production by writing a new EmbeddingStore implementation.
ATTENDAI_AI_STORAGE_DIR=./storage/embeddings

# Verification thresholds. Embeddings are L2-normalised, so distance is in [0, 2].
# - distance <= verify_threshold       -> VERIFIED
# - distance <= low_confidence_band    -> LOW_CONFIDENCE (still passes)
# - otherwise                          -> FAILED
ATTENDAI_AI_VERIFY_THRESHOLD=0.55
ATTENDAI_AI_LOW_CONFIDENCE_BAND=0.70
ATTENDAI_AI_EMBEDDING_DIM=128

# CORS - comma-separated. Lock this down to your backend host in production.
ATTENDAI_AI_CORS_ORIGINS=*
