# Copy to .env and fill in real values.

# Database (used when running outside docker-compose)
DB_USER=attendai
DB_PASSWORD=attendai

# JWT signing secret. MUST be at least 32 characters in production.
# Generate one with: openssl rand -base64 48
JWT_SECRET=replace-this-with-a-long-random-secret-of-at-least-32-characters

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AI microservice
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_KEY=dev-service-key
