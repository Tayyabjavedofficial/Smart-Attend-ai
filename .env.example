# AttendAI stack - environment configuration
# Copy this file to `.env` and edit values that matter for your deployment.
# Every variable has a sensible default, so an unedited `.env` (or no `.env`
# at all) will still produce a working dev stack.

# ----- MySQL -----
DB_NAME=attendai
DB_USER=attendai
DB_PASSWORD=attendai
DB_ROOT_PASSWORD=rootpass
DB_HOST_PORT=3306

# ----- JWT signing -----
# CHANGE THIS in production. Must be at least 32 chars for HS256.
JWT_SECRET=change-me-this-is-a-development-only-secret-do-not-use-in-production-please

# ----- Service-to-service auth between backend and AI service -----
AI_SERVICE_KEY=dev-service-key

# Use the real Python AI service (`false`) or the in-process Java stub (`true`).
AI_USE_STUB=false

# Face backend inside the AI service: `stub` | `opencv`.
# For `opencv` you must also uncomment the apt install in attendai-ai-service/Dockerfile.
AI_FACE_BACKEND=stub

# ----- Public URLs -----
# What the browser uses to reach the backend (NOT the docker network alias).
# In a typical local run, this is the host:port the backend container is mapped to.
BACKEND_PUBLIC_URL=http://localhost:8080
FRONTEND_PUBLIC_URL=http://localhost:3000

# ----- Host port mappings -----
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=3000
AI_HOST_PORT=8000
